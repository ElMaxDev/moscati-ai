# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/auralis-health?retryWrites=true&w=majority

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Azure Speech (expuesto al browser)
NEXT_PUBLIC_AZURE_SPEECH_KEY=your_azure_speech_key_here
NEXT_PUBLIC_AZURE_SPEECH_REGION=eastus

# ElevenLabs
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here

# Solana (opcional)
NEXT_PUBLIC_SOLANA_NETWORK=devnet
